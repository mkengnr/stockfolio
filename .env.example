# App
DEBUG=true
# 32+ chars required when DEBUG=false (e.g. `openssl rand -hex 32`)
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://stockfolio:stockfolio@localhost:5432/stockfolio
DATABASE_URL_SYNC=postgresql+psycopg2://stockfolio:stockfolio@localhost:5432/stockfolio

# Redis
REDIS_URL=redis://localhost:6379/0
PRICE_CACHE_TTL=300

# JWT
JWT_ACCESS_EXPIRE_HOURS=24
JWT_REMEMBER_ME_DAYS=30

# OTP
OTP_EXPIRE_MINUTES=10
OTP_REQUEST_COOLDOWN_SECONDS=60

# Email (set EMAIL_CONSOLE_FALLBACK=false to send through SMTP)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
# For Gmail, set an app password here. Never commit the real value.
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
SMTP_TIMEOUT=30
EMAIL_CONSOLE_FALLBACK=true
